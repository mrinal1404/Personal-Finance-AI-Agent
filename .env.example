# ─────────────────────────────────────────────────────────────────────────────
# Personal Finance AI Agent — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose either "openai" or "anthropic"
LLM_PROVIDER=openai

# ── OpenAI (if LLM_PROVIDER=openai) ──────────────────────────────────────────

OPENAI_API_KEY=sk-your-openai-api-key-her
OPENAI_MODEL=gpt-4o-mini        # or gpt-4o, gpt-4-turbo

# ── Anthropic (if LLM_PROVIDER=anthropic) ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ── FastAPI Server ────────────────────────────────────────────────────────────
API_PORT=8000
API_HOST=0.0.0.0

# ── Streamlit ─────────────────────────────────────────────────────────────────
STREAMLIT_PORT=8501
